{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "python /path/to/session-stats.py",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python /path/to/workflow-guard.py",
        "timeout": 5000
      }
    ]
  }
}
